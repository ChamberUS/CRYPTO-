# BYX generic Linux deploy env (Ubuntu/Debian)

# Binary and user
BYXD_BIN=/usr/local/bin/byxd
BYX_USER=byx
BYX_GROUP=byx

# Home and data
BYX_HOME=/var/lib/byxd
BYX_CHAIN_ID=byx-devnet-private-1
BYX_MONIKER=byx-node-1
BYX_GENESIS_FILE=/opt/byx/genesis.json

# Network
BYX_MIN_GAS_PRICES=0.025ubyx
BYX_P2P_LADDR=tcp://0.0.0.0:26656
BYX_EXTERNAL_ADDRESS=
BYX_PERSISTENT_PEERS=
BYX_SEEDS=
BYX_PEX=false

# Keep RPC/API local by default
BYX_RPC_LADDR=tcp://127.0.0.1:26657
BYX_API_ENABLE=true
BYX_API_ADDRESS=tcp://127.0.0.1:1317
BYX_GRPC_ENABLE=true
BYX_GRPC_ADDRESS=127.0.0.1:9090
BYX_PPROF_LADDR=localhost:6060
BYX_PROMETHEUS=true
BYX_PROMETHEUS_LISTEN=tcp://127.0.0.1:26660

# Optional pruning
BYX_PRUNING=custom
BYX_PRUNING_KEEP_RECENT=10000
BYX_PRUNING_KEEP_EVERY=0
BYX_PRUNING_INTERVAL=10

# Systemd/ops
BYX_SERVICE_NAME=byxd
BYX_ENV_FILE=/etc/byxd/byxd.env
BYX_LOG_LEVEL=info

# Backup
BYX_BACKUP_DIR=/var/backups/byx
BYX_BACKUP_KEEP_DAYS=7
