[Unit]
Description=BYX backend API - DEVNET TESTE FECHADO
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/byx/integrations/byx-backend
EnvironmentFile=/etc/byx/byx-backend.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/var/lib/byxd

[Install]
WantedBy=multi-user.target
