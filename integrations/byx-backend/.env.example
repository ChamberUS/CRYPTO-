# BYX backend API - DEVNET / TESTE FECHADO only.
PORT=8080
# Keep NODE_ENV unset or "development" for local runs.
# If your process manager sets NODE_ENV=production, set BYX_BACKEND_ALLOW_PRODUCTION=true explicitly.
NODE_ENV=development
BYX_BACKEND_ALLOW_PRODUCTION=false

# Chain access. Keep RPC private to this backend; the app should call this API.
NODE=tcp://127.0.0.1:26657
CHAIN_ID=byx-devnet
BYXD_HOME=/var/lib/byxd
KEYRING_BACKEND=test
BYXD_BIN=byxd

# HTTP auth. Use a long random value in closed tests.
BYX_BACKEND_API_TOKEN=replace-with-long-random-devnet-token
# Set only for local throwaway testing.
BYX_ALLOW_UNAUTHENTICATED=false

# Local keyring key names. Do not place mnemonics or private keys here.
BYX_CREATE_PAYMENT_KEY=merchant-key-name
BYX_DEVNET_PAYER_KEY=payer-key-name

# Tx tuning for devnet.
BYX_TX_FEES=5000byx
BYX_TX_GAS=auto
BYX_TX_GAS_ADJUSTMENT=1.3
BYX_MAX_PAYMENT_MICROBYX=1000000000000
BYX_CLI_TIMEOUT_MS=20000
BYX_TX_WAIT_MS=15000
